# Supabase (https://app.supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# サーバー側でのみ使用（スタッフ作成など管理操作）。絶対にクライアントへ露出させないこと。
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Claude API（AIシフト生成のLLM補助/店舗ルール参照生成で使用。未設定ならソルバーのみで動作）
ANTHROPIC_API_KEY=sk-ant-xxxxx
# 使用モデル（未設定時の既定は claude-sonnet-4-6）
ANTHROPIC_MODEL=claude-sonnet-4-6

# ===== 店舗ルール（「Claudeで生成」機能が参照） =====
# 店舗基本情報
STORE_NAME=全力ストレッチ岐阜長良店
STORE_OPERATING_HOURS_START=10:00
STORE_OPERATING_HOURS_END=22:00
STORE_BEDS=4
STORE_MAX_CONCURRENT_STAFF=4
STORE_CONTRACT_TYPE=アルバイト
# シフト種別定義（JSON）
STORE_SHIFT_TYPES='[{"id":"early","name":"早番","start":"10:00","end":"19:00","workHours":8,"breakMinutes":60},{"id":"late","name":"遅番","start":"13:00","end":"22:00","workHours":8,"breakMinutes":60},{"id":"short_5h","name":"早短5h","start":"10:00","end":"15:00","workHours":5,"breakMinutes":0},{"id":"short_6h","name":"早短6h","start":"10:00","end":"16:00","workHours":6,"breakMinutes":0}]'
# 日別 人数配置ルール（JSON）
STORE_STAFFING_RULES='{"saturday":{"min":3,"target":4},"sunday":{"min":3,"target":4},"weekday":{"min":3,"target":4}}'
# 時間帯別 稼働人数（JSON）
STORE_HOURLY_MIN_STAFF='{"10-13":2,"13-15":3,"15-19":2,"19-22":2}'
STORE_HOURLY_TARGET_STAFF='{"10-13":2,"13-15":4,"15-19":3,"19-22":2}'
# 勤務ルール
STORE_MIN_HOURS_PER_DAY=5
STORE_MIN_DAYS_PER_WEEK=2
STORE_WEEKEND_REQUIRED=true
STORE_BREAK_THRESHOLD_HOURS=6
STORE_BREAK_DURATION_MINUTES=60
STORE_MAX_WORK_HOURS_PER_DAY=8
# 社会保険
STORE_SOCIAL_INSURANCE_THRESHOLD_HOURS=30
STORE_SOCIAL_INSURANCE_EXPANDED_APPLICABLE=false
STORE_SOCIAL_INSURANCE_EMPLOYER_RATE=0.15
# 繁忙期（JSON）
STORE_BUSY_PERIODS='["GW","OBON","YEAREND"]'

# サロンボード連携（ブラウザ自動操作 / RPA）
# 自店舗の正規アカウントのみで利用すること。2段階認証が有効な場合は自動ログインできません。
# SALONBOARD_LOGIN_ID と SALONBOARD_PASSWORD の両方が設定されると連携が有効になります。
# あわせて `npm install playwright && npx playwright install chromium` が必要です。
# SALONBOARD_LOGIN_ID=
# SALONBOARD_PASSWORD=
# 以下は任意（画面変更に追従するためのセレクタ上書き。未設定なら既定値を使用）
# SALONBOARD_LOGIN_URL=https://salonboard.com/login/
# SALONBOARD_SEL_ID=input[name="userId"]
# SALONBOARD_SEL_PW=input[name="password"]
# SALONBOARD_SEL_LOGIN_BTN=button[type="submit"]
# SALONBOARD_SEL_LOGGEDIN=text=ログアウト
# SALONBOARD_HEADLESS=true

# ===== 公開URL（LINE通知のリンク等に使用） =====
# 本番の独自ドメイン。未設定だと通知内リンクが相対パスになります。
# NEXT_PUBLIC_APP_URL=https://shift.andsync.jp

# ===== LINE ログイン（LINE Login チャネル） =====
# 設定するとログイン画面に「LINEでログイン」が出ます（NEXT_PUBLIC_LINE_LOGIN=1）。
# 詳細・手順は docs/LINE_INTEGRATION.md を参照。
# NEXT_PUBLIC_LINE_LOGIN=1
# LINE_LOGIN_CHANNEL_ID=
# LINE_LOGIN_CHANNEL_SECRET=
# LINE_LOGIN_REDIRECT_URI=https://shift.andsync.jp/auth/line/callback

# ===== LINE 通知（Messaging API チャネル） =====
# 設定するとシフト公開・休み希望の承認/却下時にLINEへ自動通知します。
# 未設定なら通知は送られません（アプリは通常どおり動作）。
# LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=
# LINE_MESSAGING_CHANNEL_SECRET=
